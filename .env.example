# Direct bağlantı URL (Prisma migrate için - port 5432)
DIRECT_URL="postgresql://postgres.ulhvegqcoihwnecwumjd:[DB_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Supabase API (Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://ulhvegqcoihwnecwumjd.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
